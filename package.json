{
  "name": "alexandre-sdd-portfolio",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:corpus": "npm run build --workspace @portfolio/interview-core",
    "build:api": "npm run build --workspace @portfolio/interview-api",
    "build": "npm run build:corpus && npm run build:api",
    "dev:api": "npm run dev --workspace @portfolio/interview-api",
    "test": "npm run test --workspace @portfolio/interview-core && npm run test --workspace @portfolio/interview-api"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
